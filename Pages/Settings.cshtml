@page
@model HirschNotify.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings";
    var isVelocity = Model.Get("EventSource:Mode", "WebSocket") == "VelocityAdapter";
}

<style>
    /* ── Settings Layout ─────────────────────────── */
    .settings-wrap {
        display: flex;
        gap: 2.5rem;
        align-items: flex-start;
    }

    /* Secondary sidebar nav */
    .settings-nav {
        position: sticky;
        top: 1rem;
        align-self: flex-start;
        min-width: 180px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding-top: 0.5rem;
    }
    .settings-nav a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-secondary);
        transition: all 0.15s var(--ease);
        text-decoration: none;
    }
    .settings-nav a:hover { background: rgba(0, 165, 153, 0.08); color: var(--text); }
    .settings-nav a.active { background: rgba(0, 165, 153, 0.12); color: var(--electric-teal); font-weight: 600; }
    .settings-nav a svg { flex-shrink: 0; opacity: 0.6; }
    .settings-nav a:hover svg, .settings-nav a.active svg { opacity: 1; }
    .settings-nav .nav-divider { height: 1px; background: var(--border-subtle); margin: 0.5rem 0; }

    /* Main content area */
    .settings-content { flex: 1; min-width: 0; }

    /* Settings section: title on left, card on right */
    .settings-section {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
        gap: 2rem;
        padding: 2rem 0;
        border-bottom: 1px solid var(--border-subtle);
        scroll-margin-top: 1rem;
    }
    .settings-section:first-of-type { padding-top: 0.5rem; }
    .settings-section:last-of-type { border-bottom: none; }

    .settings-section-header h2 {
        font-size: 1rem;
        font-weight: 650;
        margin: 0 0 0.35rem;
        color: var(--text);
    }
    .settings-section-header p {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
    }

    /* Card container */
    .settings-card {
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-xs);
        overflow: hidden;
    }
    .settings-card-body { padding: 1.5rem; }
    .settings-card-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 0.75rem 1.5rem;
        border-top: 1px solid var(--border-subtle);
        background: var(--surface-hover);
    }

    /* 12-column grid inside cards */
    .field-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 1.25rem 1rem;
    }
    .field { display: flex; flex-direction: column; }
    .col-3 { grid-column: span 3; }
    .col-4 { grid-column: span 4; }
    .col-5 { grid-column: span 5; }
    .col-6 { grid-column: span 6; }
    .col-8 { grid-column: span 8; }
    .col-9 { grid-column: span 9; }
    .col-12 { grid-column: span 12; }

    /* Tighter form fields inside cards */
    .settings-card label {
        display: block;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.4rem;
    }
    .settings-card input,
    .settings-card select,
    .settings-card textarea {
        width: 100%;
        padding: 0.5rem 0.75rem;
        font-size: 0.88rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--surface);
        color: var(--text);
        transition: all 0.15s var(--ease);
    }
    .settings-card input:focus,
    .settings-card select:focus,
    .settings-card textarea:focus {
        outline: none;
        border-color: var(--electric-teal);
        box-shadow: 0 0 0 3px rgba(0, 165, 153, 0.12);
    }
    .settings-card small {
        display: block;
        color: var(--text-muted);
        font-size: 0.78rem;
        margin-top: 0.35rem;
    }
    .settings-card details {
        grid-column: span 12;
        margin-top: 0.5rem;
        padding-top: 1rem;
        border-top: 1px dashed var(--border-subtle);
    }
    .settings-card details summary {
        cursor: pointer;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
    }
    .settings-card details[open] summary { margin-bottom: 1rem; }
    .settings-card details .field-grid { padding-top: 0.5rem; }

    /* Stacked layout for mobile / small screens */
    @@media (max-width: 900px) {
        .settings-section { grid-template-columns: 1fr; gap: 1rem; padding: 1.5rem 0; }
        .settings-nav { display: none; }
        .col-3, .col-4, .col-5, .col-6, .col-8, .col-9 { grid-column: span 12; }
    }

    /* Velocity service-account callout */
    .velocity-account-callout {
        display: flex;
        gap: 0.85rem;
        padding: 0.9rem 1rem;
        background: rgba(0, 165, 153, 0.06);
        border: 1px solid rgba(0, 165, 153, 0.25);
        border-radius: var(--radius-sm);
        margin-bottom: 1.25rem;
    }
    .velocity-account-icon {
        flex-shrink: 0;
        color: var(--electric-teal);
        margin-top: 0.1rem;
    }
    .velocity-account-body { flex: 1; min-width: 0; }
    .velocity-account-title {
        font-size: 0.85rem;
        font-weight: 650;
        color: var(--text);
        margin-bottom: 0.3rem;
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .velocity-account-identity {
        font-family: "IBM Plex Mono", monospace;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--electric-teal);
        background: rgba(0, 165, 153, 0.12);
        padding: 0.1rem 0.45rem;
        border-radius: var(--radius-sm);
    }
    .velocity-account-body p {
        margin: 0;
        font-size: 0.8rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    /* Push relay — request flow states */
    .relay-pending-card,
    .relay-rejected-card {
        display: flex;
        gap: 0.85rem;
        padding: 0.9rem 1rem;
        border-radius: var(--radius-sm);
        margin-bottom: 1rem;
        align-items: flex-start;
    }
    .relay-pending-card {
        background: rgba(0, 165, 153, 0.06);
        border: 1px solid rgba(0, 165, 153, 0.25);
    }
    .relay-rejected-card {
        background: rgba(199, 74, 86, 0.08);
        border: 1px solid rgba(199, 74, 86, 0.3);
    }
    .relay-pending-spinner {
        flex-shrink: 0;
        color: var(--electric-teal);
        margin-top: 0.1rem;
        animation: relay-pending-spin 1.6s linear infinite;
    }
    @@keyframes relay-pending-spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
    .relay-pending-body { flex: 1; min-width: 0; }
    .relay-pending-title,
    .relay-rejected-title {
        font-size: 0.9rem;
        font-weight: 650;
        color: var(--text);
        margin-bottom: 0.35rem;
    }
    .relay-pending-body p,
    .relay-rejected-card p {
        margin: 0 0 0.5rem;
        font-size: 0.82rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }
    .relay-pending-body dl {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.2rem 0.6rem;
        margin: 0.5rem 0 0;
        font-size: 0.78rem;
    }
    .relay-pending-body dt { color: var(--text-muted); font-weight: 600; }
    .relay-pending-body dd { color: var(--text); margin: 0; font-family: "IBM Plex Mono", monospace; }
    .relay-pending-body code,
    .relay-rejected-card code { font-family: "IBM Plex Mono", monospace; font-size: 0.78rem; }

    .relay-idle-info {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.25rem 0.75rem;
        margin: 0 0 0.85rem;
        font-size: 0.85rem;
    }
    .relay-idle-info dt { color: var(--text-muted); font-weight: 600; }
    .relay-idle-info dd { color: var(--text); margin: 0; font-family: "IBM Plex Mono", monospace; font-size: 0.82rem; }
    .form-warning {
        padding: 0.55rem 0.85rem;
        background: rgba(232, 168, 30, 0.1);
        border: 1px solid rgba(232, 168, 30, 0.3);
        color: #e8a81e;
        border-radius: var(--radius-sm);
        font-size: 0.82rem;
        margin: 0 0 0.85rem;
    }
    .relay-advanced {
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px dashed var(--border-subtle);
    }
    .relay-advanced summary {
        cursor: pointer;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
    }

    /* Inline registered card */
    .registered-status {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1rem;
        background: rgba(146, 212, 0, 0.08);
        border: 1px solid rgba(146, 212, 0, 0.25);
        border-radius: var(--radius-sm);
        margin-bottom: 1rem;
    }
    .registered-status dl { display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 0.75rem; font-size: 0.82rem; margin: 0; }
    .registered-status dt { color: var(--text-muted); font-weight: 600; }
    .registered-status dd { color: var(--text); margin: 0; font-family: "IBM Plex Mono", monospace; font-size: 0.78rem; }
</style>

@if (TempData["Success"] is string msg)
{
    <div class="flash-success">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="flash-error">@err</div>
}

<div class="settings-wrap">
    <nav class="settings-nav" id="settingsNav">
        <a href="#general" class="active">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            General
        </a>
        <a href="#eventsource">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Event Source
        </a>
        <a href="#velocity" id="navVelocity" style="@(isVelocity ? "" : "display:none")">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>
            Velocity Adapter
        </a>
        <a href="#websocket" id="navWebSocket" style="@(isVelocity ? "display:none" : "")">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
            WebSocket
        </a>
        <div class="nav-divider"></div>
        <a href="#relay">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
            Push Relay
        </a>
        <div class="nav-divider"></div>
        <a href="#actions">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Actions
        </a>
        @if (Model.IsWindows)
        {
            <a href="#serviceaccount">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Service Account
            </a>
        }
        <div class="nav-divider"></div>
        <a href="#about">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            About
        </a>
    </nav>

    <div class="settings-content">
        <form method="post">

            <!-- General -->
            <section id="general" class="settings-section">
                <div class="settings-section-header">
                    <h2>General</h2>
                    <p>Identity and health monitoring settings for this service instance.</p>
                </div>
                <div class="settings-card">
                    <div class="settings-card-body">
                        <div class="field-grid">
                            <div class="field col-8">
                                <label for="serviceName">Service Name</label>
                                <input type="text" id="serviceName" name="Settings[Service:Name]" value="@Model.Get("Service:Name")" placeholder="Airport Terminal A" required />
                                <small>Identifies this service instance in the mobile app.</small>
                            </div>
                            <div class="field col-4">
                                <label for="disconnectAlert">Disconnect Alert (sec)</label>
                                <input type="number" id="disconnectAlert" name="Settings[WebSocket:DisconnectAlertSec]" value="@Model.Get("WebSocket:DisconnectAlertSec", "120")" min="1" />
                                <small>Alert after being disconnected this long.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Event Source -->
            <section id="eventsource" class="settings-section">
                <div class="settings-section-header">
                    <h2>Event Source</h2>
                    <p>Configure how events are received from the access control system. Changing the mode requires a service restart.</p>
                </div>
                <div class="settings-card">
                    <div class="settings-card-body">
                        <div class="field-grid">
                            <div class="field col-12">
                                <label for="eventSourceMode">Mode</label>
                                <select id="eventSourceMode" name="Settings[EventSource:Mode]">
                                    <option value="WebSocket" selected="@(Model.Get("EventSource:Mode", "WebSocket") == "WebSocket")">WebSocket</option>
                                    <option value="VelocityAdapter" selected="@(Model.Get("EventSource:Mode", "WebSocket") == "VelocityAdapter")">Velocity Adapter (Direct SQL)</option>
                                </select>
                                <small>WebSocket connects to a Velocity Web API event stream. Velocity Adapter connects directly to the Velocity SQL database via the SDK — typically used when this service is installed on the Velocity server itself, but it can also connect to a remote Velocity instance if you fill in the connection details below.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Velocity Adapter -->
            <section id="velocity" class="settings-section" style="@(isVelocity ? "" : "display:none")">
                <div class="settings-section-header">
                    <h2>Velocity Adapter</h2>
                    <p>Connection details for the Velocity SQL database. When this service is installed on the Velocity server itself, leave these blank — values are read automatically from <code>HKLM\SOFTWARE\Wow6432Node\Hirsch Electronics\Velocity\Client</code>. Fill them in to connect to a <strong>remote</strong> Velocity instance from a machine that doesn't have the Velocity client registry.</p>
                </div>
                <div class="settings-card">
                    <div class="settings-card-body">
                        <div class="velocity-account-callout">
                            <div class="velocity-account-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                            <div class="velocity-account-body">
                                <div class="velocity-account-title">
                                    Service Account
                                    <span class="velocity-account-identity">@Model.CurrentServiceAccount</span>
                                </div>
                                <p>This service connects to Velocity using <strong>Windows integrated authentication</strong> — the SQL session is opened with the identity above. For Velocity Adapter mode to work, this account must <strong>also be configured as a Velocity Operator</strong> inside Velocity. To change the service account, scroll down to the <a href="#serviceaccount">Service Account</a> section.</p>
                            </div>
                        </div>

                        <div class="field-grid">
                            <div class="field col-8">
                                <label for="velocitySqlServer">SQL Server Instance</label>
                                <input type="text" id="velocitySqlServer" name="Settings[Velocity:SqlServer]" value="@Model.Get("Velocity:SqlServer")" placeholder="VELAPP01\HIRSCH" />
                                <small>Hostname or IP of the SQL Server, optionally with an instance name. Required for remote installs; auto-detected from the registry on local installs.</small>
                            </div>
                            <div class="field col-4">
                                <label for="velocityDatabase">Database</label>
                                <input type="text" id="velocityDatabase" name="Settings[Velocity:Database]" value="@Model.Get("Velocity:Database")" placeholder="Velocity" />
                            </div>

                            <div class="field col-12">
                                <label for="velocityAppRole">Application Role</label>
                                <textarea id="velocityAppRole" name="EncryptedSettings[Velocity:AppRole]" rows="2" placeholder="@(string.IsNullOrEmpty(Model.Get("Velocity:AppRole")) ? "Encrypted blob — auto-detected from the Velocity registry on local installs. Required for remote installs." : "•••••••• (configured)")" autocomplete="off" spellcheck="false"></textarea>
                                <small>Velocity application role string. The Velocity client stores this as an encrypted blob under <code>HKLM\SOFTWARE\Wow6432Node\Hirsch Electronics\Velocity\Client\ApplicationRole</code> — for a remote install, export that registry value from a machine that has the Velocity client and paste it here. The SDK's <code>ConnectDecrypt</code> decrypts it at connect time.</small>
                            </div>

                            <details>
                                <summary>Advanced: Timeouts</summary>
                                <div class="field-grid">
                                    <div class="field col-6">
                                        <label for="velocityConnectTimeout">Connection Timeout (sec)</label>
                                        <input type="number" id="velocityConnectTimeout" name="Settings[Velocity:ConnectionTimeoutSec]" value="@Model.Get("Velocity:ConnectionTimeoutSec", "15")" min="1" />
                                        <small>How long to wait for the SDK to establish the initial TCP + SQL session.</small>
                                    </div>
                                    <div class="field col-6">
                                        <label for="velocityCommandTimeout">SQL Command Timeout (sec)</label>
                                        <input type="number" id="velocityCommandTimeout" name="Settings[Velocity:CommandTimeoutSec]" value="@Model.Get("Velocity:CommandTimeoutSec", "")" min="0" placeholder="SDK default" />
                                        <small>Timeout for individual SQL queries the SDK runs. Leave blank to use the SDK's default. Calls <code>VelocityServer.setSQLTimeout</code>.</small>
                                    </div>
                                </div>
                            </details>
                        </div>
                    </div>
                </div>
            </section>

            <!-- WebSocket -->
            <section id="websocket" class="settings-section" style="@(isVelocity ? "display:none" : "")">
                <div class="settings-section-header">
                    <h2>WebSocket Connection</h2>
                    <p>Endpoint and authentication details for the Velocity Web API event stream.</p>
                </div>
                <div class="settings-card">
                    <div class="settings-card-body">
                        <div class="field-grid">
                            <div class="field col-6">
                                <label for="wsUrl">Endpoint URL</label>
                                <input type="text" id="wsUrl" name="Settings[WebSocket:Url]" value="@Model.Get("WebSocket:Url")" placeholder="wss://example.com/events" />
                            </div>
                            <div class="field col-6">
                                <label for="loginUrl">Login URL</label>
                                <input type="text" id="loginUrl" name="Settings[WebSocket:LoginUrl]" value="@Model.Get("WebSocket:LoginUrl")" placeholder="https://example.com/auth/login" />
                            </div>
                            <div class="field col-4">
                                <label for="wsUsername">Username</label>
                                <input type="text" id="wsUsername" name="Settings[WebSocket:Username]" value="@Model.Get("WebSocket:Username")" />
                            </div>
                            <div class="field col-4">
                                <label for="wsPassword">Password</label>
                                <input type="password" id="wsPassword" name="EncryptedSettings[WebSocket:Password]" placeholder="@(string.IsNullOrEmpty(Model.Get("WebSocket:Password")) ? "" : "********")" />
                            </div>
                            <div class="field col-4">
                                <label for="wsDomain">Domain</label>
                                <input type="text" id="wsDomain" name="Settings[WebSocket:Domain]" value="@Model.Get("WebSocket:Domain")" />
                            </div>
                            <div class="field col-6">
                                <label for="reconnectBase">Reconnect Base Delay (sec)</label>
                                <input type="number" id="reconnectBase" name="Settings[WebSocket:ReconnectBaseDelaySec]" value="@Model.Get("WebSocket:ReconnectBaseDelaySec", "5")" min="1" />
                            </div>
                            <div class="field col-6">
                                <label for="reconnectMax">Reconnect Max Delay (sec)</label>
                                <input type="number" id="reconnectMax" name="Settings[WebSocket:ReconnectMaxDelaySec]" value="@Model.Get("WebSocket:ReconnectMaxDelaySec", "300")" min="1" />
                            </div>

                            <details>
                                <summary>Advanced: Field Name Mapping</summary>
                                <div class="field-grid">
                                    <div class="field col-4">
                                        <label for="usernameField">Request Username Field</label>
                                        <input type="text" id="usernameField" name="Settings[WebSocket:UsernameField]" value="@Model.Get("WebSocket:UsernameField")" placeholder="UserName" />
                                    </div>
                                    <div class="field col-4">
                                        <label for="passwordField">Request Password Field</label>
                                        <input type="text" id="passwordField" name="Settings[WebSocket:PasswordField]" value="@Model.Get("WebSocket:PasswordField")" placeholder="Password" />
                                    </div>
                                    <div class="field col-4">
                                        <label for="tokenField">Response Token Field</label>
                                        <input type="text" id="tokenField" name="Settings[WebSocket:TokenField]" value="@Model.Get("WebSocket:TokenField")" placeholder="Token" />
                                    </div>
                                </div>
                            </details>
                        </div>
                    </div>
                </div>
            </section>

            <div style="display: flex; justify-content: flex-end; padding: 1.5rem 0;">
                <button type="submit">Save Settings</button>
            </div>
        </form>

        <!-- Push Relay -->
        @if (Model.RelayState == "pending")
        {
            <!-- Auto-refresh while pending so the UI flips to registered as soon as the polling worker completes the handshake. -->
            <meta http-equiv="refresh" content="10" />
        }
        <section id="relay" class="settings-section">
            <div class="settings-section-header">
                <h2>Push Relay</h2>
                <p>Register this service with the push relay so paired devices can receive notifications.</p>
            </div>
            <div class="settings-card">
                <div class="settings-card-body">
                    @if (Model.RelayState == "registered")
                    {
                        <div class="registered-status">
                            <mark>Registered</mark>
                            <dl>
                                <dt>Service Name:</dt><dd>@Model.Get("Service:Name")</dd>
                                <dt>Instance ID:</dt><dd>@Model.Get("Relay:InstanceId")</dd>
                                <dt>Relay URL:</dt><dd>@Model.EffectiveRelayUrl</dd>
                            </dl>
                        </div>
                        <form method="post" asp-page-handler="UnregisterRelay" onsubmit="return confirm('Unregister from the push relay? All paired devices will stop receiving notifications.');">
                            <button type="submit" class="btn-danger">Unregister from Relay</button>
                        </form>
                    }
                    else if (Model.RelayState == "pending")
                    {
                        var requestIdShort = Model.Get("Relay:RequestId");
                        if (requestIdShort.Length > 8) requestIdShort = requestIdShort.Substring(0, 8);

                        <div class="relay-pending-card">
                            <div class="relay-pending-spinner">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </div>
                            <div class="relay-pending-body">
                                <div class="relay-pending-title">Waiting for admin approval</div>
                                <p>Submitted as <strong>@Model.Get("Service:Name")</strong>. The page will auto-refresh and switch to "Registered" as soon as your request is approved.</p>
                                <dl>
                                    <dt>Request ID:</dt><dd><code>@requestIdShort…</code></dd>
                                    <dt>Submitted:</dt><dd>@Model.Get("Relay:RequestedAt")</dd>
                                </dl>
                            </div>
                        </div>
                        <form method="post" asp-page-handler="CancelRegistrationRequest">
                            <button type="submit" class="btn-danger">Cancel request</button>
                        </form>
                    }
                    else if (Model.RelayState == "rejected" || Model.RelayState == "expired")
                    {
                        var headline = Model.RelayState == "rejected" ? "Request rejected" : "Request expired";
                        <div class="relay-rejected-card">
                            <div class="relay-rejected-title">@headline</div>
                            <p>@Model.Get("Relay:RejectionReason")</p>
                        </div>
                        <form method="post" asp-page-handler="DismissRegistrationResult">
                            <button type="submit">Dismiss and try again</button>
                        </form>
                    }
                    else
                    {
                        var serviceName = Model.Get("Service:Name");
                        var canRequest = !string.IsNullOrWhiteSpace(serviceName);

                        <dl class="relay-idle-info">
                            <dt>Relay URL:</dt><dd>@Model.EffectiveRelayUrl</dd>
                        </dl>
                        <p class="text-muted-msg">
                            Submit a registration request to the relay administrator. Once approved, this instance will automatically pick up its credentials and connect — no token to copy and paste.
                        </p>
                        @if (!canRequest)
                        {
                            <p class="form-warning">Set a Service Name above first — the relay admin needs it to identify your install.</p>
                        }
                        <form method="post" asp-page-handler="RequestRegistrationToken">
                            <button type="submit" disabled="@(!canRequest)">Request Registration Token</button>
                        </form>

                        <details class="relay-advanced">
                            <summary>Advanced — self-host your own relay</summary>
                            <form method="post">
                                <div class="field-grid">
                                    <div class="field col-12">
                                        <label for="customRelayUrl">Relay URL override</label>
                                        <input type="url" id="customRelayUrl" name="Settings[Relay:Url]" value="@Model.Get("Relay:Url")" placeholder="@HirschNotify.Services.RelayUrlResolver.Default" />
                                        <small>Leave blank to use the default <code>@HirschNotify.Services.RelayUrlResolver.Default</code>. Changing this affects all subsequent relay calls.</small>
                                    </div>
                                </div>
                                <button type="submit">Save override</button>
                            </form>
                        </details>
                    }
                </div>
            </div>
        </section>

        <!-- Actions -->
        <section id="actions" class="settings-section">
            <div class="settings-section-header">
                <h2>Actions</h2>
                <p>Test the event source connection and send a test notification.</p>
            </div>
            <div class="settings-card">
                <div class="settings-card-body">
                    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                        @if (isVelocity)
                        {
                            <form method="post" asp-page-handler="TestVelocityConnection">
                                <button type="submit" class="outline">Test Velocity Connection</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="TestConnection">
                                <button type="submit" class="outline">Test WebSocket Connection</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="TestNotification">
                            <button type="submit" class="outline">Send Test Notification</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        @if (Model.IsWindows)
        {
            <!-- Service Account -->
            <section id="serviceaccount" class="settings-section">
                <div class="settings-section-header">
                    <h2>Service Account</h2>
                    <p>Change the Windows account the HirschNotify service runs as. The service will restart under the new credentials — this page will reconnect automatically in ~15 seconds.</p>
                </div>
                <div class="settings-card">
                    <div class="settings-card-body">
                        <div class="velocity-account-callout">
                            <div class="velocity-account-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                            <div class="velocity-account-body">
                                <div class="velocity-account-title">
                                    Currently running as
                                    <span class="velocity-account-identity">@Model.CurrentServiceAccount</span>
                                </div>
                                <p>Applying a new account will grant it <strong>Log on as a service</strong>, grant read/execute on the install directory (plus modify on <code>Logs</code>, <code>Data</code>, and <code>Keys</code>), update the SCM record, and restart the service. Encrypted settings are preserved because DPAPI keys are machine-scoped. If the new account fails to start the service, HirschNotify automatically rolls back to <code>LocalSystem</code>.</p>
                            </div>
                        </div>

                        <form method="post" asp-page-handler="SetServiceAccount" autocomplete="off"
                              onsubmit="return confirm('Change the service account and restart? This browser session will disconnect for ~15 seconds.');">
                            <div class="field-grid">
                                <div class="field col-6">
                                    <label for="svcUsername">Username</label>
                                    <input type="text" id="svcUsername" name="username" placeholder="DOMAIN\Username" required autocomplete="off" />
                                    <small>Use <code>DOMAIN\Username</code> for domain accounts, <code>.\Username</code> for local accounts.</small>
                                </div>
                                <div class="field col-6">
                                    <label for="svcPassword">Password</label>
                                    <input type="password" id="svcPassword" name="password" required autocomplete="new-password" />
                                    <small>Not stored — passed directly to the Service Control Manager.</small>
                                </div>
                            </div>
                            <div style="padding-top: 1rem;">
                                <button type="submit" class="btn-danger">Apply &amp; Restart</button>
                            </div>
                        </form>
                    </div>
                </div>
            </section>
        }

        <!-- About -->
        @{
            var updateAvailable = Model.UpdateState.IsUpdateAvailable();
            var latestManifest = Model.UpdateState.LatestManifest;
            var lastCheckedText = Model.UpdateState.LastCheckedAt?.ToLocalTime().ToString("g") ?? "never";
            var lastCheckError = Model.UpdateState.LastCheckError;
        }
        <section id="about" class="settings-section">
            <div class="settings-section-header">
                <h2>About</h2>
                <p>Version information and update status. HirschNotify automatically checks for new releases every 6 hours.</p>
            </div>
            <div class="settings-card">
                <div class="settings-card-body">
                    <dl class="about-grid">
                        <dt>Current version</dt>
                        <dd><code>v@HirschNotify.Services.UpdateState.CurrentVersion</code></dd>

                        <dt>Last checked</dt>
                        <dd>@lastCheckedText</dd>

                        @if (!string.IsNullOrEmpty(lastCheckError) && !updateAvailable)
                        {
                            <dt>Status</dt>
                            <dd class="about-error">Update check failed — @lastCheckError</dd>
                        }
                    </dl>

                    @if (updateAvailable && latestManifest is not null)
                    {
                        <div class="about-update-available">
                            <div class="about-update-header">
                                <strong>v@latestManifest.Version is available</strong>
                                <form method="post" asp-page-handler="InstallUpdate"
                                      onsubmit="return confirm('Install v@latestManifest.Version now? The service will stop, files will be replaced, and the service will restart. This browser session will reconnect in ~30 seconds.');">
                                    <button type="submit">Update to v@latestManifest.Version</button>
                                </form>
                            </div>
                            <details class="about-release-notes">
                                <summary>Release notes</summary>
                                <pre class="release-notes-body">@latestManifest.ReleaseNotes</pre>
                            </details>
                        </div>
                    }
                    else if (!updateAvailable && string.IsNullOrEmpty(lastCheckError))
                    {
                        <p class="about-uptodate">You're on the latest version.</p>
                    }
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const nav = document.getElementById('settingsNav');
        const links = nav.querySelectorAll('a[href^="#"]');
        const sections = document.querySelectorAll('.settings-section');

        function updateActive() {
            let current = '';
            sections.forEach(function (section) {
                const rect = section.getBoundingClientRect();
                if (rect.top <= 100) current = section.id;
            });
            links.forEach(function (link) {
                link.classList.toggle('active', link.getAttribute('href') === '#' + current);
            });
        }

        links.forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });

        window.addEventListener('scroll', updateActive, { passive: true });
        updateActive();

        // Toggle event source sections (Velocity Adapter ↔ WebSocket are mutually exclusive)
        const modeSelect = document.getElementById('eventSourceMode');
        const velocitySection = document.getElementById('velocity');
        const websocketSection = document.getElementById('websocket');
        const navVelocity = document.getElementById('navVelocity');
        const navWebSocket = document.getElementById('navWebSocket');

        function toggleEventSource() {
            const isVel = modeSelect.value === 'VelocityAdapter';
            velocitySection.style.display = isVel ? '' : 'none';
            websocketSection.style.display = isVel ? 'none' : '';
            navVelocity.style.display = isVel ? '' : 'none';
            navWebSocket.style.display = isVel ? 'none' : '';
        }
        modeSelect.addEventListener('change', toggleEventSource);
    });
</script>
}
