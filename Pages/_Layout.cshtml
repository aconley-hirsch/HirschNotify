@inject HirschNotify.Services.UpdateState UpdateState
@inject HirschNotify.Services.ISettingsService SettingsSvc
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hirsch Notify</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
@{
    // TempData["Restarting"] is set by handlers that kick off a service
    // restart (service account change, in-app updater). The inline script
    // below polls /health every 2s when this flag is set and reloads the
    // page on the first successful response.
    var restartingAttr = TempData["Restarting"] is true ? "true" : null;

    // Update banner — renders when an update is available AND the user
    // hasn't already dismissed this specific version. Per-version dismissal
    // is stored server-side in Updates:LastDismissedVersion, so a newer
    // release automatically re-arms the banner even after a previous
    // dismissal.
    HirschNotify.Services.UpdateManifest? updateToShow = null;
    if (User.Identity?.IsAuthenticated == true && UpdateState.IsUpdateAvailable())
    {
        var dismissed = await SettingsSvc.GetAsync("Updates:LastDismissedVersion");
        var latest = UpdateState.LatestManifest;
        if (latest is not null && latest.Version != dismissed)
        {
            updateToShow = latest;
        }
    }
}
<body data-restarting="@restartingAttr">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="~/images/hirsch_logo-darkmode.png" alt="Hirsch" class="sidebar-logo" />
            </div>

            <nav class="sidebar-nav">
                <a href="/" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                    Dashboard
                </a>
                <a href="/Rules" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Rules") == true ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                    Rules
                </a>
                <a href="/Recipients" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Recipients") == true ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Recipients
                </a>
                <a href="/Groups" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Groups") == true ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                    Groups
                </a>
<a href="/Logs" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Logs" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                    Logs
                </a>
                <a href="/Integrations" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Integrations" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.6 2.7a10 10 0 0 1 5.7 5.7"/><path d="M2.7 8.4a10 10 0 0 1 5.7-5.7"/><path d="M8.4 21.3a10 10 0 0 1-5.7-5.7"/><path d="M21.3 15.6a10 10 0 0 1-5.7 5.7"/><circle cx="12" cy="12" r="2"/><path d="m15 9-3 3"/><path d="m9 15 3-3"/></svg>
                    Integrations
                </a>
                <a href="/Settings" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Settings" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    Settings
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="/Login?handler=Logout" class="nav-item nav-logout">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Logout
                </a>
            </div>
        </aside>

        <div class="main-wrapper">
            @if (updateToShow is not null)
            {
                <div id="updateBanner" class="update-banner" data-version="@updateToShow.Version">
                    <div class="update-banner-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M5 12l7-7 7 7"/></svg>
                    </div>
                    <div class="update-banner-body">
                        <strong>Update available: v@(updateToShow.Version)</strong>
                        <span> — <a href="/Settings#about">View details</a> to install now.</span>
                    </div>
                    <button type="button" class="update-banner-dismiss" onclick="dismissUpdateBanner('@updateToShow.Version')" aria-label="Dismiss">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
            }
            <header class="page-header">
                <h1>@ViewData["Title"]</h1>
                @await RenderSectionAsync("PageActions", required: false)
            </header>
            <main class="app-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main class="app-content app-content--unauth">
            @RenderBody()
        </main>
    }

    <script src="~/htmx.min.js"></script>
    <script src="~/alpine.min.js" defer></script>
    <script>
        function dismissUpdateBanner(version) {
            fetch('/updates/dismiss', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ version: version })
            }).finally(function () {
                var el = document.getElementById('updateBanner');
                if (el) el.remove();
            });
        }
    </script>
    <script>
        // Reconnect-after-restart poller. Activates when a handler sets
        // TempData["Restarting"] = true (service account change, auto-update
        // reinstall). Polls /health every 2s, reloads on first 200 response.
        (function () {
            if (document.body.dataset.restarting !== 'true') return;

            var overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;display:flex;align-items:center;justify-content:center;color:#fff;font-family:Manrope,sans-serif;font-size:1.1rem;';
            overlay.innerHTML = '<div style="background:#1a1f2e;padding:2rem 3rem;border-radius:12px;text-align:center;"><div style="font-weight:600;margin-bottom:0.75rem;">Service restarting</div><div style="opacity:0.8;font-size:0.9rem;">Reconnecting…</div></div>';
            document.body.appendChild(overlay);

            var attempts = 0;
            function poll() {
                attempts++;
                fetch('/health', { cache: 'no-store' })
                    .then(function (r) {
                        if (r.ok) { window.location.reload(); return; }
                        setTimeout(poll, 2000);
                    })
                    .catch(function () {
                        if (attempts > 60) { overlay.querySelector('div > div:last-child').textContent = 'Still waiting…'; }
                        setTimeout(poll, 2000);
                    });
            }
            // Wait a beat before the first probe so the restart helper has a
            // chance to actually stop the service — otherwise the first poll
            // hits the still-running old process and reloads immediately.
            setTimeout(poll, 3000);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
